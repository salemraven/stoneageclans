# Copy to config.env and edit. config.env is gitignored.
# Optional: run.sh and RUN_AI_CLAN_TEST.sh source this when present.

# Path to Godot executable (required for headless runs)
# macOS:   /Applications/Godot.app/Contents/MacOS/Godot
# Linux:   /usr/bin/godot or /usr/bin/godot4
export GODOT_PATH="/Applications/Godot.app/Contents/MacOS/Godot"

# Default run duration in seconds (ai-clan and smoke use this when not overridden)
export DEFAULT_DURATION=120

# Where to put all test run outputs (smoke, ai-clan, automate)
# Relative to Tests/ or absolute. Empty = use Tests/results
export RESULTS_DIR="results"
