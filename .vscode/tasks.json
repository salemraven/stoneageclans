{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Godot: Verify Cursor/VS Code setup",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/verify_vscode_godot_setup.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Godot: Headless smoke (3s)",
      "type": "shell",
      "command": "tools/godot/godot.cmd",
      "args": [
        "--headless",
        "--path",
        "${workspaceFolder}",
        "--quit-after",
        "180"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Godot: Headless + playtest + RTS pack",
      "type": "shell",
      "command": "tools/godot/godot.cmd",
      "args": [
        "--headless",
        "--path",
        "${workspaceFolder}",
        "--quit-after",
        "180",
        "--",
        "--playtest-capture",
        "--rts-playtest-spawn"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
